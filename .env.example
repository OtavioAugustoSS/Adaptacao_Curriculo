# Banco de dados — Postgres (ADR-0025). Em dev, use um Postgres local (Docker) ou uma
# branch de dev do Neon/Supabase. Em produção (Vercel), defina como env da plataforma.
DATABASE_URL="postgresql://user:password@localhost:5432/forja?schema=public"

# IA — NVIDIA NIM (endpoint compatível com OpenAI)
LLM_BASE_URL="https://integrate.api.nvidia.com/v1"
LLM_API_KEY=""
MODEL_ID="meta/llama-3.3-70b-instruct"

# Autenticação — Auth.js / OAuth (ADR-0024).
# AUTH_SECRET: gere com `npx auth secret` (ou `openssl rand -base64 33`).
AUTH_SECRET=""
# Em produção atrás de proxy, defina a URL pública (ex.: https://seu-app.vercel.app).
# AUTH_URL="http://localhost:3000"
# Credenciais OAuth (auto-detectadas pelo Auth.js pelos nomes abaixo):
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Identidade — FALLBACK de DEV/TESTE apenas (ADR-0024 §3). Fora de produção, quando não
# há sessão, o seam getCurrentUserId() usa este id. Em produção é inerte (sem sessão → 401).
LOCAL_USER_ID="local-user"
