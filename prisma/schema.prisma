// Forja de Currículo — modelo de dados. Ver docs/erd.md.
// Multiusuário em Postgres (ADR-0025; antes SQLite no MVP, ADR-0005). Campos que
// guardam JSON (bullets, techStack, *Json, etc.) seguem como String contendo JSON
// serializado — a (de)serialização vive só nos repositórios (ADR-0005).
//
// Autenticação real via Auth.js/OAuth (ADR-0024): os modelos Account/Session/
// VerificationToken são exigidos pelo @auth/prisma-adapter; o User ganha os campos
// padrão do adapter (name/image/emailVerified). O `userId` segue em toda entidade
// de domínio (multi-tenant), acessado sempre pelo seam getCurrentUserId().

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// --- Autenticação (Auth.js / @auth/prisma-adapter) -------------------------

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  name          String?
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())

  // Auth.js
  accounts Account[]
  sessions Session[]

  // Domínio (multi-tenant por userId)
  profile          Profile?
  experiences      Experience[]
  educations       Education[]
  skills           Skill[]
  projects         Project[]
  languages        Language[]
  courses          Course[]
  jobPostings      JobPosting[]
  generatedResumes GeneratedResume[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// --- Domínio ---------------------------------------------------------------

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName  String
  phone     String?
  location  String?
  email     String?
  linkedin  String?
  github    String?
  website   String?
  summary   String?
  updatedAt DateTime @updatedAt

  experiences Experience[]
  educations  Education[]
  skills      Skill[]
  projects    Project[]
  languages   Language[]
  courses     Course[]
}

model Experience {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  company   String
  role      String
  location  String?
  startDate String
  endDate   String?
  current   Boolean @default(false)
  bullets   String  @default("[]") // JSON: string[]
  order     Int     @default(0)

  @@index([userId])
}

model Education {
  id          String  @id @default(cuid())
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileId   String
  profile     Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  institution String
  degree      String
  field       String?
  startDate   String
  endDate     String?
  current     Boolean @default(false)
  gpa         String?
  details     String?
  order       Int     @default(0)

  @@index([userId])
}

model Skill {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  category  String
  name      String
  level     String?
  order     Int     @default(0)

  @@index([userId])
}

model Project {
  id          String  @id @default(cuid())
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileId   String
  profile     Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name        String
  description String
  bullets     String  @default("[]") // JSON: string[]
  techStack   String  @default("[]") // JSON: string[]
  url         String?
  order       Int     @default(0)

  @@index([userId])
}

model Language {
  id          String  @id @default(cuid())
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileId   String
  profile     Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name        String
  proficiency String
  order       Int     @default(0)

  @@index([userId])
}

model Course {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title     String
  issuer    String
  date      String
  url       String?
  order     Int     @default(0)

  @@index([userId])
}

model JobPosting {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rawText        String
  title          String?
  company        String?
  parsedKeywords String? // JSON
  createdAt      DateTime @default(now())

  generatedResumes GeneratedResume[]

  @@index([userId])
}

model GeneratedResume {
  id                 String      @id @default(cuid())
  userId             String
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name               String // nome editável do usuário (ADR-0021); default no app (rótulo do modo + data)
  mode               String // "STANDARD" | "JOB_ADAPTIVE"
  isDefault          Boolean     @default(false) // currículo padrão do usuário (ADR-0022; no máx. 1, garantido na escrita)
  jobPostingId       String?
  jobPosting         JobPosting? @relation(fields: [jobPostingId], references: [id], onDelete: SetNull)
  modelId            String
  contentJson        String // JSON: ResumeContent validado
  texOutput          String // o .tex renderizado (cache)
  traceabilityReport String? // JSON
  createdAt          DateTime    @default(now())

  @@index([userId])
}
